# ============================================================
# CENTRAL CONFIGURATION FILE
# All time, schedule, email, and branch settings live here.
# Change values here — all workflows will pick them up.
# ============================================================

# --- Schedules (UTC times) ---
# IST = UTC + 5:30
# 12:00 PM IST = 06:30 UTC  → TEST to PROD
SCHEDULE_TEST_TO_PROD="30 6 * * *"

# PROD to main runs after TEST_TO_PROD completes (chained via workflow_run event)
# No separate schedule needed — it triggers automatically.

# --- Branch Names ---
BRANCH_SOURCE_TEST="TEST"
BRANCH_SOURCE_PROD="PROD"
BRANCH_TARGET_PROD="PROD"
BRANCH_TARGET_MAIN="main"

# --- Email ---
NOTIFY_EMAIL="canvatemp71@gmail.com"

# --- Retry / Hold Policy ---
# On conflict: skip today, retry tomorrow (handled by conflict detection logic)
CONFLICT_HOLD_DAYS=1
